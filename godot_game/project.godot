[gd_project]

config_version=5
name="Tower of Souls - A Souls-Like Platformer"
version="0.1.0"

[application]

config/name="Tower of Souls"
config/version="0.1.0"
run/main_scene="res://scenes/world/main.tscn"
config/features=PackedStringArray("4.5", "2d")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/vsync_mode=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

2d/default_gravity=980

[rendering]

textures/canvas_textures/default_texture_filter=1
