[gd_project]

config_version=5
name="Tower of Souls - A Souls-Like Platformer"
version="0.1.0"

[application]

config/name="Tower of Souls"
config/version="0.1.0"
run/main_scene="res://scenes/world/main.tscn"
config/features=PackedStringArray("4.5", "2d")

[input]

ui_accept={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194309), InputEventJoypadButton(device=0, button_index=0)]
}
ui_select={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=32)]
}
ui_cancel={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194305), InputEventJoypadButton(device=0, button_index=1)]
}
ui_focus_next={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194320)]
}
ui_focus_prev={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194319)]
}
ui_left={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=65), InputEventJoypadMotion(device=0, axis=0, axis_value=-1.0)]
}
ui_right={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=68), InputEventJoypadMotion(device=0, axis=0, axis_value=1.0)]
}
ui_up={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=87), InputEventJoypadMotion(device=0, axis=1, axis_value=-1.0)]
}
ui_down={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=83), InputEventJoypadMotion(device=0, axis=1, axis_value=1.0)]
}
player_light_attack={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194306), InputEventJoypadButton(device=0, button_index=2)]
}
player_heavy_attack={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194307), InputEventJoypadButton(device=0, button_index=3)]
}
player_dodge={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194308), InputEventJoypadButton(device=0, button_index=5)]
}
player_block={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194325), InputEventJoypadButton(device=0, button_index=4)]
}
player_sprint={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=4194325), InputEventJoypadButton(device=0, button_index=9)]
}
player_interact={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=69), InputEventJoypadButton(device=0, button_index=0)]
}
player_jump={
	"deadzone": 0.5,
	"events": [InputEventKey(keycode=32), InputEventJoypadButton(device=0, button_index=0)]
}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/vsync_mode=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

2d/default_gravity=980
2d/default_linear_damp=0.0
2d/default_angular_damp=0.0

[rendering]

textures/canvas_textures/default_texture_filter=1
